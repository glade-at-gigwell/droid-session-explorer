{
  "name": "droid-session-explorer",
  "version": "0.2.2",
  "description": "dsx: CLI + TUI for searching and analyzing Factory Droid sessions",
  "type": "module",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
